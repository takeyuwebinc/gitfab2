// For format details, see https://containers.dev/implementors/json_reference/.
// For config options, see the README at: https://github.com/devcontainers/templates/tree/main/src/ruby
{
  "name": "gitfab2",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "docker-compose.yml"
  ],
  "service": "app",
  "workspaceFolder": "/src",
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "${localEnv:HOME}/.claude"
  },
  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  "forwardPorts": [
    3000
  ],
  // Configure tool-specific properties.
  // "customizations": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code"
      ],
      "settings": {}
    }
  },
  // Uncomment to connect as root instead. More info: https://containers.dev/implementors/json_reference/#remoteUser.
  "remoteUser": "ruby",
  "initializeCommand": "mkdir -p ${localEnv:HOME}/.config/gh",
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=${localEnv:HOME}/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/gh,target=/home/ruby/.config/gh,type=bind,consistency=cached"
  ],
  // Use 'postCreateCommand' to run commands after the container is created.
  "postCreateCommand": "bash .devcontainer/sync-docker-gid.sh && bash .devcontainer/claude-setup.sh && cp config/database.ymls/development.yml config/database.yml"
}